<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/action_encrypt"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">
        <Button
            android:id="@+id/btn_select_files"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/action_select_files" />
        <Button
            android:id="@+id/btn_select_folder"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/action_select_folder" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/rg_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rb_stego_png"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mode_stego_png"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rb_encrypted_archive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/mode_encrypted_archive" />
    </RadioGroup>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_passphrase"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="@string/label_passphrase"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_generate_qr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_generate_qr"/>
    </LinearLayout>

    <Button
        android:id="@+id/btn_start_encrypt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/action_encrypt" />

    <ImageView
        android:id="@+id/iv_qr_code"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

</LinearLayout>